# ── API Gateway ────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=api-gateway
JWT_EXPIRES=1h
# Comma-separated paths that skip auth entirely
JWT_PUBLIC_PATHS=/health,/metrics,/ready

# ── Upstream services (JSON array) ────────────────────────────────────────────
UPSTREAMS=[{"prefix":"/api/users","target":"http://localhost:8081"},{"prefix":"/api/orders","target":"http://localhost:8082"}]

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60000

# ── DDoS protection ────────────────────────────────────────────────────────────
DDOS_RPS=100
DDOS_BURST=2.0
DDOS_BAN_MS=300000
DDOS_SLOWLORIS=5000
MAX_PAYLOAD_BYTES=1048576

# ── Input sanitisation ─────────────────────────────────────────────────────────
SANITISE_XSS=true
SANITISE_SQL=true
SANITISE_PATH=true
MAX_STRING_LEN=10000
ALLOWED_CT=application/json,application/x-www-form-urlencoded,multipart/form-data

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# ── Observability: ELK ────────────────────────────────────────────────────────
ELK_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=
ELK_INDEX=gateway-transactions
ELK_FLUSH_BYTES=1048576
ELK_FLUSH_INTERVAL=5000

# ── Observability: Prometheus / Grafana ───────────────────────────────────────
METRICS_ENABLED=true
METRICS_PATH=/metrics

# ── Observability: OpenTelemetry ──────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=api-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Docker Compose ports ──────────────────────────────────────────────────────
GATEWAY_PORT=3000
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin
KIBANA_PORT=5601
