{
  "name": "node-ts-api-gateway",
  "version": "1.0.0",
  "description": "Security & compliance API gateway with input sanitisation, DDoS protection, and centralised observability (Grafana/ELK)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-prometheus": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.4",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^2.15.0",
    "pino": "^9.3.2",
    "pino-elasticsearch": "^8.0.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.12.0",
    "@vitest/coverage-v8": "^2.0.3",
    "eslint": "^9.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
