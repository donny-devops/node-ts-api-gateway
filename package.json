{
  "name": "node-ts-api-gateway",
  "version": "1.0.1",
  "description": "Security and compliance API gateway with input sanitisation, DDoS protection, and centralised observability.",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/http-proxy": "^9.5.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-otlp-grpc": "^0.52.1",
    "@opentelemetry/exporter-prometheus": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^2.15.0",
    "pino": "^9.3.2",
    "pino-elasticsearch": "^8.0.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/node": "^20.14.11",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.12.0",
    "@vitest/coverage-v8": "^2.0.3",
    "eslint": "^9.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
